{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://willitcall.dev/schemas/transcript-v1.schema.json",
  "title": "willitcall transcript v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "scenario_id", "turns"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string"
    },
    "scenario_id": {
      "type": "string"
    },
    "turns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/turn"
      }
    }
  },
  "$defs": {
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "request", "response", "retried"],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "request": {
          "$ref": "#/$defs/request"
        },
        "response": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/response"
            }
          ]
        },
        "retried": {
          "type": "boolean"
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "url", "headers", "body"],
      "properties": {
        "method": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "headers": {
          "$ref": "#/$defs/headers"
        },
        "body": {
          "type": "object"
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "headers"],
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "headers": {
          "$ref": "#/$defs/headers"
        },
        "body_raw": {
          "type": "string"
        },
        "body_raw_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]*$"
        }
      },
      "oneOf": [
        {
          "required": ["body_raw"],
          "not": {
            "required": ["body_raw_hex"]
          }
        },
        {
          "required": ["body_raw_hex"],
          "not": {
            "required": ["body_raw"]
          }
        }
      ]
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
